# Compiled class file
*.class

# Log file
*.log

# BlueJ files
*.ctxt

# Mobile Tools for Java (J2ME)
.mtj.tmp/

# Package Files #
*.jar
*.war
*.nar
*.ear
*.zip
*.tar.gz
*.rar

# virtual machine crash logs, see http://www.java.com/en/download/help/error_hotspot.xml
hs_err_pid*
replay_pid*

# Private planning artifacts (Epics / Stories / Tasks). Never reference IDs
# from this tree in committed source, commits, or PR descriptions.
docs/

# Node / build outputs
node_modules/
.vitest-cache/

# Temporary golden ROM working dirs (live alongside committed goldens)
tests/golden/*.tmp/

# Upstream usm clone built by tests/goldens.mjs at the pinned SHA
tests/.upstream-clone/

# Claude Code local state
.claude/

# Built artifacts from the LZSS C harness (source is committed; binary isn't)
tests/lzss-c-harness/lzcompress
tests/lzss-c-harness/lzcompress.exe
